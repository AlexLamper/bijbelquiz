{
  "name": "bijbelquiz-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:all": "turbo dev --parallel",
    "dev:web:host": "npm run dev --workspace=@bijbelquiz/web -- -H 192.168.68.107",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "prettier": "^3.0.0",
    "turbo": "latest"
  },
  "packageManager": "npm@10.2.4",
  "dependencies": {
    "@bijbelquiz/database": "^0.0.0",
    "@hookform/resolvers": "^5.2.2",
    "expo-dev-client": "~6.0.20",
    "lucide-react": "^1.7.0",
    "mongoose": "^9.4.1",
    "next": "^16.2.2",
    "next-auth": "^4.24.13",
    "react": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "zod": "^4.3.6"
  }
}
